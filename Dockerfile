# 1️⃣ استخدام إصدار Node.js مستقر ومتوافق مع خوادم Hugging Face
FROM node:20

# 2️⃣ تعيين مجلد العمل الرئيسي بداخل الحاوية بصلاحيات كاملة
WORKDIR /App

# 3️⃣ نسخ ملفات الحزم مباشرة من المجلد الرئيسي للمشروع
COPY package*.json ./

# 4️⃣ تثبيت الحزم والمكتبات البرمجية المطلوبة للسيرفر بنقاء
RUN npm install --omit=dev

# 👑 [صمام كسر الكاش الأزلي لـ The HONOR] تحديث الوقت لإجبار Hugging Face على بناء السيرفر من الصفر دون كاش معلق
ENV CACHE_BUST="2026-06-26-v1"

# 5️⃣ نسخ بقية ملفات المشروع وأكواد السيرفر لداخل الحاوية
COPY . .

# 6️⃣ فتح المنفذ الإجباري والوحيد لمنصات Hugging Face Docker
EXPOSE 7860
ENV PORT=7860

# 7️⃣ أمر تشغيل السيرفر السحابي لـ The HONOR
CMD ["node", "server.js"]
