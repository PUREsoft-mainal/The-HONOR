# استخدام بيئة Node.js الرسمية والمستقرة
FROM node:20

# تحديد مجلد العمل داخل السيرفر
WORKDIR /app

# نسخ ملفات الحزم أولاً لتثبيتها
COPY package*.json ./

# تثبيت المكتبات
RUN npm install

# نسخ باقي ملفات المشروع بالكامل
COPY . .

# فتح المنفذ الافتراضي لهجينج فيس
EXPOSE 7860

# أمر تشغيل السيرفر المستخرج
CMD ["node", "server.js"]
