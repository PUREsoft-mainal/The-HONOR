<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>The HONOR - إدارة الشركة</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header>
        <!-- 1. شريط الموظف المطور في الأعلى تماماً بدلاً من شريط اسم المستخدم -->
        <div class="employee-bar">
            <div>👤 الموظف الحالي: <strong><%= user.username %></strong> | المعرّف الحصري: [<%= user.emp_id %>] <% if(user.role==='admin'){ %>(المدير العام)<% } %></div>
            <a href="/logout">تسجيل الخروج 🚪</a>
        </div>

        <!-- 2. شريط الأزرار في الهيدر تحت شريط الموظف مباشرة -->
        <div class="nav-buttons-bar">
            <a href="/" class="btn-nav">🏠 الرئيسية</a>
            <% if(user.role === 'admin') { %>
                <!-- زر موظف جديد الحصري للآدمن -->
                <button onclick="createNewEmployee()" class="btn-nav btn-new-emp">➕ موظف جديد</button>
            <% } %>
            <button onclick="alert('قسم المراسلات قيد التطوير بنظام Socket.io')" class="btn-nav">💬 المراسلة</button>
            <button onclick="alert('الملفات والتقارير الرسمية لشركة The HONOR')" class="btn-nav">📂 المستندات</button>
        </div>

        <!-- 3. اللوجو متموضع بين شريط الأزرار ومساحة عرض منشورات الآدمن -->
        <div class="logo-container">
            <img src="/images/logo.png" alt="The HONOR Logo" onerror="this.style.display='none'; this.after('✨ شركة The HONOR ✨')">
        </div>
    </header>

    <div class="main-container">

        <!-- مساحة منشورات الآدمن (صندوق النشر للآدمن فقط) -->
        <% if(user.role === 'admin') { %>
            <div class="admin-publish-box">
                <form action="/posts/create" method="POST">
                    <textarea name="content" placeholder="اكتب منشوراً جديداً ليظهر على الصفحة الرئيسية لكل الموظفين..." required></textarea>
                    <button type="submit">نشر للشركة الآن</button>
                </form>
            </div>
        <% } %>

        <!-- تيار عرض منشورات الفيس بوك -->
        <div class="posts-stream">
            <% posts.forEach(post => { %>
                <div class="fb-post">
                    <div class="post-header">
                        <div class="author-info">
                            <div class="author-avatar">H</div>
                            <div>
                                <div class="author-name">The HONOR (إدارة النظام)</div>
                                <div class="post-time"><%= new Date(post.created_at).toLocaleString('ar-EG') %></div>
                            </div>
                        </div>
                        
                        <!-- أزرار الحذف والتعديل للآدمن فقط -->
                        <% if(user.role === 'admin') { %>
                            <div class="admin-actions">
                                <button onclick="editPost('<%= post.id %>', `<%= post.content %>`)" class="btn-action-post">✏️ تعديل</button>
                                <form action="/posts/delete/<%= post.id %>" method="POST" style="display:inline;" onsubmit="return confirm('هل تريد بالتأكيد حذف هذا المنشور نهائياً؟')">
                                    <button type="submit" class="btn-action-post delete">🗑️ حذف</button>
                                </form>
                            </div>
                        <% } %>
                    </div>

                    <!-- محتوى المنشور -->
                    <div class="post-content"><%= post.content %></div>

                    <!-- إحصائيات المنشور -->
                    <div class="post-stats">
                        <span>👍 <%= post.likes_count %> إعجاب</span>
                        <span>💬 <%= post.comments ? post.comments.length : 0 %> تعليق</span>
                    </div>

                    <!-- أزرار التفاعل (تم إلغاء زر المشاركة تماماً بناءً على طلبك) -->
                    <div class="post-interactions">
                        <form action="/posts/like/<%= post.id %>" method="POST">
                            <button type="submit" class="interact-btn <%= post.user_liked ? 'liked' : '' %>">
                                👍 <%= post.user_liked ? 'تم الإعجاب' : 'إعجاب' %>
                            </button>
                        </form>
                        <button class="interact-btn" onclick="document.getElementById('comment-inp-<%= post.id %>').focus()">
                            💬 تعليق
                        </button>
                    </div>

                    <!-- قسم التعليقات -->
                    <div class="comments-section">
                        <% if(post.comments && post.comments.length > 0) { %>
                            <% post.comments.forEach(comment => { %>
                                <div class="comment-box">
                                    <div>
                                        <span class="comment-user"><%= comment.emp_username %>:</span>
                                        <span><%= comment.content %></span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>

                        <!-- نموذج إضافة تعليق موظف -->
                        <form action="/posts/comment/<%= post.id %>" method="POST" class="comment-form">
                            <input type="text" name="comment_content" id="comment-inp-<%= post.id %>" class="comment-input" placeholder="اكتب تعليقاً حياً..." required>
                            <button type="submit" class="comment-submit">↩️</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        // دالة إنشاء موظف جديد واستخراج بياناته بشكل مستقل
        function createNewEmployee() {
            const username = prompt("أدخل اسم الموظف الجديد (سيتم استخدامه كاسم مستخدم للدخول):");
            if (!username || username.trim() === "") return;

            fetch('/employees/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: username.trim() })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    alert(`🎉 تم إنشاء حساب الموظف الجديد بنجاح في The HONOR!\n\nاسم المستخدم الحصري: ${data.data.username}\nكلمة المرور المستخرجة: ${data.data.rawPassword}\nالرقم التعريفي الموحد (ID): ${data.data.empId}\n\n⚠️ يرجى حفظ هذه البيانات وإرسالها للموظف.`);
                    window.location.reload();
                } else {
                    alert("خطأ: " + data.message);
                }
            });
        }

        // دالة تعديل المنشور الحصري للآدمن
        function editPost(id, oldContent) {
            const newContent = prompt("قم بتعديل نص المنشور الحالي:", oldContent);
            if (newContent && newContent.trim() !== "") {
                fetch(`/posts/edit/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: newContent })
                }).then(() => window.location.reload());
            }
        }
    </script>
</body>
</html>
